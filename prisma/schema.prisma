// Prisma schema for "Own the World" — virtual land marketplace

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  displayName  String
  passwordHash String
  createdAt    DateTime @default(now())

  plots            Plot[]
  listings         Listing[]
  boughtTx         Transaction[] @relation("BuyerTx")
  soldTx           Transaction[] @relation("SellerTx")
}

model Plot {
  id            String   @id @default(cuid())
  gridX         Int
  gridY         Int
  centerLat     Float
  centerLng     Float
  name          String?
  color         String   @default("#22c55e")
  locationLabel String?
  purchasePrice Float
  purchasedAt   DateTime @default(now())

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  listings     Listing[]
  transactions Transaction[]

  // A grid cell can only be owned once — guarantees no overlapping plots.
  @@unique([gridX, gridY])
  @@index([centerLat, centerLng])
  @@index([ownerId])
}

enum ListingStatus {
  ACTIVE
  SOLD
  CANCELLED
}

model Listing {
  id        String        @id @default(cuid())
  plotId    String
  plot      Plot          @relation(fields: [plotId], references: [id])
  sellerId  String
  seller    User          @relation(fields: [sellerId], references: [id])
  price     Float
  status    ListingStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status])
  @@index([plotId])
}

enum TransactionType {
  PRIMARY
  RESALE
}

model Transaction {
  id        String          @id @default(cuid())
  plotId    String
  plot      Plot            @relation(fields: [plotId], references: [id])
  buyerId   String
  buyer     User            @relation("BuyerTx", fields: [buyerId], references: [id])
  sellerId  String?
  seller    User?           @relation("SellerTx", fields: [sellerId], references: [id])
  amount    Float
  type      TransactionType
  createdAt DateTime        @default(now())

  @@index([plotId])
  @@index([createdAt])
}
